  VARIABLE:
  NAMES = ID COPE1_B COPE2_B COPE3_B COPE4_B COPE5_B COPE6_B COPE7_B COPE8_B COPE9_B
       COPE10_B COPE11_B COPE12_B COPE13_B COPE14_B COPE15_B NONWHITE MALE SGM FG
       HS_BA BCHW1 BCHW2 BCHW3 BCHW4 BCHW5 BCHW6;
   MISSING=.;
   IDVARIABLE = ID;
    CATEGORICAL = COPE1_B-COPE15_B;
    CLASSES = c(6);
    TRAINING = BCHW1-BCHW6 (bch);
  ANALYSIS:
